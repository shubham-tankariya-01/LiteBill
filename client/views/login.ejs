<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/public/css/actions.css" />
<link rel="stylesheet" href="/public/css/login.css" />

<section class="auth-container">
    <h2 class="auth-header">USER_<span class="text-glow-orange">PORTAL</span></h2>

    <form class="auth-form" action="#" method="POST">
        <!-- Mobile Number -->
        <div class="form-group">
            <label class="form-label">> MOBILE_NUMBER :</label>
            <input type="tel" name="mobile" class="cyber-input-field" placeholder="Enter 10-digit number..." required />
        </div>

        <!-- Submeters Row side-by-side -->
        <div class="submeter-row">
            <div class="submeter-col" style="flex: 0.4;">
                <label class="form-label">> QTY_SUBMETERS :</label>
                <input type="number" name="submeterCount" min="0" class="cyber-input-field" placeholder="e.g. 2" />
            </div>
        </div>

        <!-- Password -->
        <div class="form-group">
            <label class="form-label">> SECURE_KEY (PASSWORD) :</label>
            <input type="password" name="password" class="cyber-input-field" placeholder="************" required />
        </div>

        <!-- Submit -->
        <div style="text-align: center; margin-top: 20px;">
            <button type="submit" class="btn-cyber btn-orange-green" style="width: 100%;">
                <span class="btn-text">INITIALIZE_SESSION</span>
                <div class="btn-glitch"></div>
            </button>
        </div>
    </form>
</section>
