<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/public/css/actions.css" />
<link rel="stylesheet" href="/public/css/readings.css" />

<section class="readings-container card-minimal">
    <div class="readings-content">
        <h2 class="readings-header">Enter <span class="text-primary">Sequence</span></h2>
        <p class="text-main text-center mb-4">Please input your 6-digit sequence down below to submit data.</p>

        <form action="#" class="readings-form">
            <div class="secure-input-group">
                <input type="text" name="reading" maxlength="6" class="minimal-sequence-input" autofocus autocomplete="off" placeholder="• • • • • •" />
            </div>

            <button type="button" class="btn-action btn-primary submit-btn" onclick="document.querySelector('.telemetry-text').innerText = 'Authenticating...'; setTimeout(() => alert('Sequence Uploaded Successfully'), 500)">
                Submit Data
            </button>
        </form>

        <div class="telemetry-deco">
            <span class="telemetry-text text-muted">Ready for input</span>
        </div>
    </div>
</section>